{
  "manifest_version": 3,
  "name": "NeuroRead AI",
  "version": "2.0.0",
  "description": "Multimodal AI accessibility for Neurodivergent Readers.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "NeuroRead AI"
  }
}
